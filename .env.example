# Anthropic
ANTHROPIC_API_KEY=

# Database (SQLite for dev, PostgreSQL URL for prod)
# Dev example:  file:/absolute/path/to/packages/db/prisma/takumi.db
# Prod example: postgresql://user:pass@host:5432/db
DATABASE_URL=

# Server
API_PORT=3001
WEB_PORT=3000

# CORS (API allows this origin). Only needed if web and API are different origins.
CORS_ORIGIN=http://localhost:3000

# Web → API proxy (Next.js rewrites). Server-only var, not exposed to browser.
API_URL=http://localhost:3001

# Basic auth (both API and Web). Leave blank for local dev to disable.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
