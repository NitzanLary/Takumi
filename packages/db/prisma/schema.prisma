generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  displayName     String?   @map("display_name")
  currencyPref    String    @default("ILS") @map("currency_pref")
  costBasisMethod String    @default("FIFO") @map("cost_basis_method")
  // Investor profile — declared by the user during onboarding or from /settings.
  // See system-prompt.ts for how these are fed into the AI agent's context.
  // `investorProfileUpdatedAt` is set on first save (even if user skips with
  // empty values), so we can tell "never shown" apart from "intentionally blank".
  investorHorizon          String?   @map("investor_horizon")           // intraday | swing | position | long_term | mixed
  investorGoal             String?   @map("investor_goal")              // aggressive_growth | steady_growth | income | preservation | learning
  investorNotes            String?   @map("investor_notes")
  investorProfileUpdatedAt DateTime? @map("investor_profile_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  sessions           Session[]
  verificationTokens VerificationToken[]
  trades             Trade[]
  alerts             Alert[]
  conversations      AiConversation[]
  snapshots          PortfolioSnapshot[]
  syncLogs           SyncLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  purpose    String    // email_verify | password_reset
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("verification_tokens")
}

// ─── Trade Records ───────────────────────────────────────────────

model Trade {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  tradeId         String   @map("trade_id")
  ticker          String
  securityName    String   @map("security_name")
  market          String   // TASE | NYSE | NASDAQ
  direction       String   // BUY | SELL
  quantity        Decimal
  price           Decimal
  currency        String   // ILS | USD
  commission      Decimal  @default(0)
  proceedsFx      Decimal? @map("proceeds_fx")       // Actual FX amount (תמורה במט"ח)
  proceedsIls     Decimal? @map("proceeds_ils")      // Actual ILS amount (תמורה בשקלים)
  capitalGainsTax Decimal? @map("capital_gains_tax") // Estimated capital gains tax
  tradeDate       DateTime @map("trade_date")
  source          String   // xlsx_import
  rawPayload      String?  @map("raw_payload") // JSON string
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tradeId, source])
  @@index([userId, tradeDate])
  @@index([ticker])
  @@index([tradeDate])
  @@index([market])
  @@map("trades")
}

// ─── Securities Reference Data ───────────────────────────────────

model Security {
  id              String  @id @default(cuid())
  ticker          String  @unique
  name            String
  market          String  // TASE | NYSE | NASDAQ
  sector          String?
  currency        String  // ILS | USD
  yahooSymbol     String? @map("yahoo_symbol")
  industry        String?
  marketCapBucket String? @map("market_cap_bucket")

  @@map("securities")
}

// ─── Sync Log ────────────────────────────────────────────────────

model SyncLog {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  syncedAt     DateTime @default(now()) @map("synced_at")
  status       String   // success | partial | failed
  recordsAdded Int      @default(0) @map("records_added")
  dateFrom     DateTime @map("date_from")
  dateTo       DateTime @map("date_to")
  fileName     String?  @map("file_name")
  errorMessage String?  @map("error_message")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncedAt(sort: Desc)])
  @@map("sync_log")
}

// ─── Alerts ──────────────────────────────────────────────────────

model Alert {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  ticker      String?
  type        String    // price_drop | price_target | holding_duration | portfolio_pnl | sync_failure | inactivity
  threshold   Decimal
  status      String    @default("active") // active | triggered | dismissed
  triggeredAt DateTime? @map("triggered_at")
  message     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("alerts")
}

// ─── Market Prices ───────────────────────────────────────────────

model MarketPrice {
  id           String   @id @default(cuid())
  ticker       String
  price        Decimal
  currency     String
  dayChange    Decimal? @map("day_change")
  dayChangePct Decimal? @map("day_change_pct")
  high52w      Decimal? @map("high_52w")
  low52w       Decimal? @map("low_52w")
  volume       Int?
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@index([ticker, fetchedAt(sort: Desc)])
  @@map("market_prices")
}

// ─── Exchange Rates ──────────────────────────────────────────────

model ExchangeRate {
  id   String   @id @default(cuid())
  date DateTime @unique
  rate Decimal  // ILS per 1 USD

  @@map("exchange_rates")
}

// ─── Portfolio Snapshots ─────────────────────────────────────────

model PortfolioSnapshot {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  date           DateTime
  totalValue     Decimal  @map("total_value")
  totalCostBasis Decimal  @map("total_cost_basis")
  unrealizedPnl  Decimal  @map("unrealized_pnl")
  realizedPnl    Decimal  @map("realized_pnl")
  positionCount  Int      @map("position_count")
  snapshotData   String?  @map("snapshot_data") // JSON string
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("portfolio_snapshots")
}

// ─── AI Conversations ────────────────────────────────────────────

model AiConversation {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  title     String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  messages  AiMessage[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String         @map("conversation_id")
  role           String         // user | assistant | tool
  content        String         // text content or JSON for tool results
  toolCalls      String?        @map("tool_calls") // JSON array of tool calls
  createdAt      DateTime       @default(now()) @map("created_at")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

